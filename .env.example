DATABASE_URL=postgresql://user:password@host:5432/claude_center

# Worker only. JSON array, matched by projectName or repoUrl against Console projects.
# 可选:也可在 Worker 桌面窗口「关联项目」区选文件夹添加（持久化到 worker.json，与此处合并去重）。
CLAUDE_CENTER_PROJECTS=[{"projectName":"Example","repoUrl":"https://github.com/acme/example.git","localPath":"D:\\src\\example"}]
CLAUDE_CENTER_WORKER_NAME=office-pc
CLAUDE_CENTER_POLL_INTERVAL_MS=10000
CLAUDE_CENTER_HEARTBEAT_INTERVAL_MS=15000
CLAUDE_CODE_COMMAND=claude
# Worker（PR 合并清理）与 Console（定时合并检查）都用它查 PR 状态：`gh pr view --json state`。
# Console 主机未登录 gh 也能跑——会回退到远程 git 祖先判定（见 docs/spec/task-merge-status-check.md）。
GH_COMMAND=gh

# Console only, optional. 定时合并检查间隔（ms），默认 60000。每轮检查一个待验收任务的
# work_branch 是否已并入 target_branch，已合并则自动验收。
# CLAUDE_CENTER_MERGE_CHECK_INTERVAL_MS=60000

# Worker only, optional. PowerShell snippet run in the SAME session right before
# `claude`, so any env vars it sets reach the claude process. Use it for proxy /
# VPN setup. Wrap the value in single quotes so the inner double quotes survive.
# 注意：此前置命令只作用于 claude 执行会话，【不】覆盖套餐用量采集（oauth/usage）的网络出口——
# 那条 curl 用下面的 CLAUDE_CENTER_USAGE_PROXY。只配这一条会导致用量永远采不到（直连被挡返回 forbidden）。
# CLAUDE_CENTER_CLAUDE_PRE_COMMAND='$env:HTTP_PROXY = "http://127.0.0.1:10808"; $env:HTTPS_PROXY = "http://127.0.0.1:10808"'

# Worker only, optional. 钉钉 CLI 作为可选「客户端能力」：开关 + 命令路径/名（如 dingtalk）。
# 默认关闭、命令空；运行时也可在 Worker 桌面端「设置 → 钉钉 CLI」开关与配置，改动持久化到
# ~/.claude-center/worker.json 覆盖此初值。开启后参与启动能力自检（runCommand --version）并随
# capabilities 上报 DB（Console 「能力」区可见）；关闭则不占任何槽位。
# CLAUDE_CENTER_DINGTALK_ENABLED=false
# CLAUDE_CENTER_DINGTALK_COMMAND=dingtalk

# Worker only, optional. 真并发执行的同时在途任务上限（每任务用独立 git worktree 隔离工作树）。默认 1。
# 运行时也可在 Worker 桌面窗口调整，改动持久化到 ~/.claude-center/worker.json 覆盖此初值。
# CLAUDE_CENTER_MAX_PARALLEL=1
# Worker only, optional. 客户端策略：是否允许 web 端远程切换工作态。默认 false。运行时也可在
# Worker 桌面窗口里开关，改动会持久化到 ~/.claude-center/worker.json 覆盖此初值。
# CLAUDE_CENTER_ALLOW_REMOTE_CONTROL=false
# Worker only, optional. 采集套餐用量（5h/7d）时访问 api.anthropic.com 的代理；缺省回退到 HTTPS_PROXY/HTTP_PROXY。
# 国内/受限网络【必须】配：否则直连 oauth/usage 被挡，Console 的「套餐用量」会一直空着（详情抽屉会显示采集失败原因）。
# 注意它与 CLAUDE_CENTER_CLAUDE_PRE_COMMAND 是两套出口，配了 pre-command 代理仍要单独配这条。
# CLAUDE_CENTER_USAGE_PROXY=http://127.0.0.1:10808
# Worker only, optional. 采集 claude 版本/订阅/用量并上报的间隔（ms）。默认 60000。
# CLAUDE_CENTER_INFO_INTERVAL_MS=60000
# Worker only, optional. 套餐用量（远程 oauth/usage）单独的采集间隔（ms）。默认 300000（5 分钟）。
# 用量窗口是 5h/7d 缓变量，无需跟随 INFO 间隔高频拉取；放慢可避开该接口限流（rate_limit_error）。
# CLAUDE_CENTER_USAGE_INTERVAL_MS=300000
# 注意：Worker 上线后默认处于「空闲」态，不接任务。需在 Worker 桌面窗口或（开启远程后）web 端
# 切到「工作状态」才会领取任务。状态以 DB 为准，重启保留。

# ===== SSE 中转服务（apps/relay）：Console↔Worker 的低延迟实时线，详见 docs/spec/sse-relay-service.md =====
# 可用时优先走 SSE（亚秒级），不可用时退回数据库轮询（功能不降级）。下列变量【全部留空=禁用中转、纯轮询】。
# Console + Worker：中转服务基址。留空则两端都不连中转、纯走数据库轮询。
# 这一项会被 console /api/relay/ticket 透传给浏览器，所以必须是【浏览器能直连】的地址。
# CLAUDE_CENTER_RELAY_URL=http://127.0.0.1:8787
# Console only, optional. 服务端 publish + /connections 代理走内网时单独配；未配则回退 RELAY_URL。
# 典型部署场景：docker compose 内 console 容器走 service name 直连 relay 容器，避免出公网回环。
# CLAUDE_CENTER_RELAY_INTERNAL_URL=http://relay:8787
# relay only, optional. 监听地址与端口（默认 127.0.0.1:8787）。
# CLAUDE_CENTER_RELAY_HOST=127.0.0.1
# CLAUDE_CENTER_RELAY_PORT=8787
# Console + relay 共享：浏览器订阅票据的 HMAC 签名密钥（自定义随机串，越长越好）。
# CLAUDE_CENTER_RELAY_SECRET=change-me-to-a-long-random-secret
# Console + Worker + relay 共享：发布事件的鉴权 token。
# CLAUDE_CENTER_RELAY_PUBLISH_TOKEN=change-me-publish-token
# Worker + relay 共享：Worker 订阅中转的鉴权 token。
# CLAUDE_CENTER_RELAY_WORKER_TOKEN=change-me-worker-token
# relay only, optional. 保活 :ping 间隔（ms，默认 15000）与每频道 Last-Event-ID 重放环容量（默认 200）。
# CLAUDE_CENTER_RELAY_PING_INTERVAL_MS=15000
# CLAUDE_CENTER_RELAY_RING_SIZE=200
